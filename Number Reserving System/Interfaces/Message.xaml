<Window x:Class="Number_Reserving_System.Interfaces.Message"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Number_Reserving_System.Interfaces"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        
        Style="{StaticResource MaterialDesignWindow}"
        
        Title="NR System - Message"
        Height="300"
        Width="700"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Border BorderBrush="White"
            Background="Brown"
            BorderThickness="5">

        <Border.Effect>

            <DropShadowEffect BlurRadius="20"
                              ShadowDepth="5"
                              Opacity="2">
                
            </DropShadowEffect>
            
        </Border.Effect>

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="30"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="1"
                  Grid.Column="1">

                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!--Message-->
                <Grid Grid.Row="1">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon Grid.Column="0"
                                             Kind="AlertCircleOutline"
                                             Width="70"
                                             Height="70"
                                             Foreground="White"
                                             VerticalAlignment="Center"
                                             HorizontalAlignment="Center"/>

                    <TextBlock Grid.Column="1"
                               Text="Error."
                               FontSize="40"
                               Foreground="White"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                </Grid>
                
                <!--Button-->
                <Grid Grid.Row="2">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            x:Name="OkBttn"
                            Width="130"
                            Height="45"
                            Background="White"
                            materialDesign:ElevationAssist.Elevation="Dp8"
                            Click="OkBttn_Click">

                        <StackPanel Orientation="Horizontal">

                            <TextBlock Text="OK"
                                       FontSize="18"
                                       Foreground="Black"
                                       VerticalAlignment="Center"
                                       FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                        </StackPanel>

                    </Button>

                </Grid>
                
            </Grid>
            
        </Grid>
        
    </Border>
</Window>
