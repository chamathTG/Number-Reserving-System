<Window x:Class="Number_Reserving_System.Interfaces.Register"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Number_Reserving_System.Interfaces"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        
        Style="{StaticResource MaterialDesignWindow}"
        
        d:DesignWidth="1920"
        d:DesignHeight="1080"
        
        Title="NR System"
        Height="700"
        Width="1000"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Background>
        <ImageBrush ImageSource="/Resources/Images/Katunayaka.jpg" Stretch="Fill"/>
    </Window.Background>
    
    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            
            <Grid.RowDefinitions>
                <RowDefinition Height="20"/>
                <RowDefinition Height="60"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!--Logout button-->
            <Grid Grid.Row="1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        x:Name="LogoutBttn"
                        Width="50"
                        Height="50"
                        Background="White"
                        materialDesign:ElevationAssist.Elevation="Dp0"
                        Click="LogoutBttn_Click">

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">

                        <materialDesign:PackIcon Kind="Close"
                                                 Width="25"
                                                 Height="25"
                                                 Foreground="Black"/>

                    </StackPanel>

                </Button>

            </Grid>
            
        </Grid>

        <!--Register Fieled-->
        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition/>
                <RowDefinition Height="100"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="1">

                <Border Grid.Row="1"
                        BorderBrush="Black"
                        Background="White"
                        BorderThickness="2"
                        CornerRadius="10">

                    <Grid>

                        <Grid.RowDefinitions>

                            <RowDefinition Height="50"/>
                            <RowDefinition/>
                            <RowDefinition Height="60"/>
                            <RowDefinition Height="60"/>
                            <RowDefinition Height="60"/>
                            <RowDefinition/>

                        </Grid.RowDefinitions>

                        <!--Text-->
                        <StackPanel Grid.Row="1"
                                    Orientation="Vertical"
                                    VerticalAlignment="Center">

                            <TextBlock Text="Wellcome!"
                                       FontSize="50"
                                       HorizontalAlignment="Center"
                                       FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                            <TextBlock Text="To the number reserving portal of"
                                       FontSize="15"
                                       HorizontalAlignment="Center"
                                       FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                            <TextBlock Text="- Department of Immigration and Emigration -"
                                       FontSize="15"
                                       FontStyle="Italic"
                                       HorizontalAlignment="Center"
                                       FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                            <TextBlock Text=""
                                       FontSize="15"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text=""
                                       FontSize="15"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="Enter your details to reserve a number for your service"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                        </StackPanel>

                        <!--Name-->
                        <TextBox Grid.Row="2"
                                 x:Name="UsernameTB"
                                 Grid.Column="1"
                                 FontSize="15"
                                 FontFamily="pack://application:,,,/assets/fonts/#Alan Sans"
                                 Padding="10"
                                 Width="400"
                                 Height="50"
                                 Foreground="Black"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Name"
                                 materialDesign:HintAssist.Foreground="Black"
                                 materialDesign:HintAssist.HintHorizontalAlignment="Center"
                                 materialDesign:TextFieldAssist.HasClearButton="True"
                                 materialDesign:TextFieldAssist.ClearButtonSize="19"/>

                        <!--Number-->
                        <TextBox Grid.Row="3"
                                 x:Name="ContactNumTB"
                                 Grid.Column="1"
                                 FontSize="15"
                                 FontFamily="pack://application:,,,/assets/fonts/#Alan Sans"
                                 Padding="10"
                                 Width="400"
                                 Height="50"
                                 Foreground="Black"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Contact Number"
                                 materialDesign:HintAssist.Foreground="Black"
                                 materialDesign:HintAssist.HintHorizontalAlignment="Center"
                                 materialDesign:TextFieldAssist.HasClearButton="True"
                                 materialDesign:TextFieldAssist.ClearButtonSize="19"/>

                        <!--ID Number-->
                        <TextBox Grid.Row="4"
                                 x:Name="IdNumTB"
                                 Grid.Column="1"
                                 FontSize="15"
                                 FontFamily="pack://application:,,,/assets/fonts/#Alan Sans"
                                 Padding="10"
                                 Width="400"
                                 Height="50"
                                 Foreground="Black"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="ID Number"
                                 materialDesign:HintAssist.Foreground="Black"
                                 materialDesign:HintAssist.HintHorizontalAlignment="Center"
                                 materialDesign:TextFieldAssist.HasClearButton="True"
                                 materialDesign:TextFieldAssist.ClearButtonSize="19"/>

                        <!--Continue Button-->
                        <Button Grid.Row="5"
                                x:Name="ContinueBttn"
                                Width="300"
                                Height="45"
                                Background="Brown"
                                materialDesign:ElevationAssist.Elevation="Dp0"
                                Click="ContinueBttn_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="CONTINUE  |  "
                                           FontSize="18"
                                           Foreground="White"
                                           VerticalAlignment="Center"
                                           FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                                <materialDesign:PackIcon Kind="InvoiceTextOutline"
                                                         Width="23"
                                                         Height="23"
                                                         Foreground="White"
                                                         VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                    </Grid>

                </Border>

            </Grid>
            
        </Grid>
        
    </Grid>
    
</Window>
