<Window x:Class="Number_Reserving_System.Interfaces.OtherServices"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Number_Reserving_System.Interfaces"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        
        Style="{StaticResource MaterialDesignWindow}"
        
        d:DesignWidth="1920"
        d:DesignHeight="1080"
        
        Title="NR System"
        Height="700"
        Width="1000"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Background>
        <ImageBrush ImageSource="/Resources/Images/Portal.jpg" Stretch="Fill"/>
    </Window.Background>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <Border Grid.Column="1"
                Grid.Row="1"
                Background="White"
                BorderBrush="Black"
                BorderThickness="2"
                CornerRadius="10">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="200"/>
                    <RowDefinition Height="170"/>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="60"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!--Text-->
                <StackPanel Grid.Row="1"
                            Orientation="Vertical"
                            VerticalAlignment="Center">

                    <TextBlock Text="If you cant find the service you need"
                               FontSize="25"
                               HorizontalAlignment="Center"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                    <TextBlock Text="in the pre-defined services list"
                               FontSize="25"
                               HorizontalAlignment="Center"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                    <TextBlock Text="Please explain your need [very simply]"
                               FontSize="25"
                               HorizontalAlignment="Center"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                    <TextBlock Text=""
                               FontSize="30"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Ex : If your passport is stolen and want to do something about it ?"
                               FontSize="20"
                               HorizontalAlignment="Center"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                    <TextBlock Text="- put the description as &quot;Stolen Passport&quot; -"
                               FontSize="20"
                               HorizontalAlignment="Center"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                </StackPanel>

                <!--Info TextBox-->
                <TextBox Grid.Row="2"
                         x:Name="InfoTB"
                         Grid.Column="1"
                         FontSize="15"
                         FontFamily="pack://application:,,,/assets/fonts/#Alan Sans"
                         Padding="10"
                         Width="500"
                         Height="50"
                         Foreground="Black"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Description"
                         materialDesign:HintAssist.Foreground="Black"
                         materialDesign:HintAssist.HintHorizontalAlignment="Center"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         materialDesign:TextFieldAssist.ClearButtonSize="19"/>

                <!--Continue Button-->
                <Button Grid.Row="3"
                        x:Name="OsContinueBttn"
                        Width="300"
                        Height="45"
                        Background="Brown"
                        materialDesign:ElevationAssist.Elevation="Dp0"
                        Click="OsContinueBttn_Click">

                    <StackPanel Orientation="Horizontal">

                        <TextBlock Text="CONTINUE"
                                   FontSize="18"
                                   Foreground="White"
                                   FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                    </StackPanel>

                </Button>

                <!--Back Button-->
                <Button Grid.Row="4"
                        x:Name="OsBackBttn"
                        Width="250"
                        Height="45"
                        Background="Brown"
                        materialDesign:ElevationAssist.Elevation="Dp0"
                        Click="OsBackBttn_Click">

                    <StackPanel Orientation="Horizontal">

                        <materialDesign:PackIcon Kind="ArrowLeftThick"
                                                 Width="20"
                                                 Height="20"
                                                 Foreground="White"
                                                 VerticalAlignment="Center"/>

                        <TextBlock Text=" |  Back"
                                   FontSize="18"
                                   Foreground="White"
                                   FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                    </StackPanel>

                </Button>

            </Grid>
            
        </Border>
        
    </Grid>
    
</Window>
