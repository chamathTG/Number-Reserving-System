<Window x:Class="Number_Reserving_System.Interfaces.Services"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Number_Reserving_System.Interfaces"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        
        Style="{StaticResource MaterialDesignWindow}"
        
        d:DesignWidth="1920"
        d:DesignHeight="1080"
        
        Title="NR System"
        Height="700"
        Width="1000"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Background>
        <ImageBrush ImageSource="/Resources/Images/Portal.jpg" Stretch="Fill"/>
    </Window.Background>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="400"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="800"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!--Back Button-->
            <Button Grid.Column="1"
                    x:Name="BackBttn"
                    Grid.Row="0"
                    Width="200"
                    Height="45"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    materialDesign:ElevationAssist.Elevation="Dp8"
                    Click="BackBttn_Click">

                <StackPanel Orientation="Horizontal">

                    <materialDesign:PackIcon Kind="ArrowLeftThick"
                                             Width="20"
                                             Height="20"
                                             Foreground="Black"
                                             VerticalAlignment="Center"/>

                    <TextBlock Text=" |  Back"
                               FontSize="18"
                               Foreground="Black"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                </StackPanel>

            </Button>

            <!--Note-->
            <Border Grid.Column="3"
                    Background="Brown"
                    BorderThickness="5"
                    CornerRadius="15"
                    Width="800"
                    Height="80"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <TextBlock Text="Select the Service you need"
                           Foreground="White"
                           FontSize="40"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

            </Border>

        </Grid>

        <Grid Grid.Row="1">

            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!--Service1 Button-->
            <Button x:Name="Serv1Btn"
                    Grid.Column="0"
                    Grid.Row="0"
                    Width="300"
                    Height="45"
                    Background="White"
                    materialDesign:ElevationAssist.Elevation="Dp8"
                    Click="Serv1Btn_Click">

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="New Passport"
                               FontSize="18"
                               Foreground="Black"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                </StackPanel>

            </Button>

            <!--Service2 Button-->
            <Button x:Name="Serv2Btn"
                    Grid.Column="1"
                    Grid.Row="0"
                    Width="300"
                    Height="45"
                    Background="White"
                    materialDesign:ElevationAssist.Elevation="Dp8"
                    Click="Serv2Btn_Click">

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="Passport Renewing"
                               FontSize="18"
                               Foreground="Black"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                </StackPanel>

            </Button>

            <!--Service3 Button-->
            <Button x:Name="Serv3Btn"
                    Grid.Column="2"
                    Grid.Row="0"
                    Width="300"
                    Height="45"
                    Background="White"
                    materialDesign:ElevationAssist.Elevation="Dp8"
                    Click="Serv3Btn_Click">

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="Damaged Passport"
                               FontSize="18"
                               Foreground="Black"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                </StackPanel>

            </Button>

            <!--Service4 Button-->
            <Button x:Name="Serv4Btn"
                    Grid.Column="0"
                    Grid.Row="1"
                    Width="300"
                    Height="45"
                    Background="White"
                    materialDesign:ElevationAssist.Elevation="Dp8"
                    Click="Serv4Btn_Click">

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="New Visa"
                               FontSize="18"
                               Foreground="Black"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                </StackPanel>

            </Button>

            <!--Service5 Button-->
            <Button x:Name="Serv5Btn"
                    Grid.Column="1"
                    Grid.Row="1"
                    Width="300"
                    Height="45"
                    Background="White"
                    materialDesign:ElevationAssist.Elevation="Dp8"
                    Click="Serv5Btn_Click">

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="Visa Extending"
                               FontSize="18"
                               Foreground="Black"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                </StackPanel>

            </Button>

            <!--Service6 Button-->
            <Button x:Name="Serv6Btn"
                    Grid.Column="2"
                    Grid.Row="1"
                    Width="300"
                    Height="45"
                    Background="White"
                    materialDesign:ElevationAssist.Elevation="Dp8"
                    Click="Serv6Btn_Click">

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="Visa Stamping"
                               FontSize="18"
                               Foreground="Black"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                </StackPanel>

            </Button>

            <!--Service7 Button-->
            <Button x:Name="Serv7Btn"
                    Grid.Column="0"
                    Grid.Row="2"
                    Width="300"
                    Height="45"
                    Background="White"
                    materialDesign:ElevationAssist.Elevation="Dp8"
                    Click="Serv7Btn_Click">

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="Document Validation"
                               FontSize="18"
                               Foreground="Black"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                </StackPanel>

            </Button>

            <!--Service8 Button-->
            <Button x:Name="Serv8Btn"
                    Grid.Column="1"
                    Grid.Row="2"
                    Width="300"
                    Height="45"
                    Background="White"
                    materialDesign:ElevationAssist.Elevation="Dp8"
                    Click="Serv8Btn_Click">

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="Travel Information"
                               FontSize="18"
                               Foreground="Black"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                </StackPanel>

            </Button>

            <!--Other Service Button-->
            <Button Grid.Column="2"
                    x:Name="OtherServiceBttn"
                    Grid.Row="2"
                    Width="300"
                    Height="45"
                    Background="White"
                    materialDesign:ElevationAssist.Elevation="Dp8"
                    Click="OtherServiceBttn_Click">

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="Other Services  | "
                               FontSize="18"
                               Foreground="Black"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                    <materialDesign:PackIcon Kind="ArrowRightThick"
                                             Width="20"
                                             Height="20"
                                             Foreground="Black"
                                             VerticalAlignment="Center"/>

                </StackPanel>

            </Button>

        </Grid>

    </Grid>
    
</Window>
