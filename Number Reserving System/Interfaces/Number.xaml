<Window x:Class="Number_Reserving_System.Interfaces.Number"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Number_Reserving_System.Interfaces"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        
        Style="{StaticResource MaterialDesignWindow}"
        
        d:DesignWidth="1920"
        d:DesignHeight="1080"
        
        Title="NR System"
        Height="700"
        Width="1000"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Background>
        <ImageBrush ImageSource="/Resources/Images/Transit.jpg" Stretch="Fill"/>
    </Window.Background>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        
        <!--Note-->
        <Grid Grid.Row="1">

            <Border Grid.Column="1"
                    Background="Brown"
                    BorderThickness="5"
                    CornerRadius="15"
                    Width="1250"
                    Height="100">

                <TextBlock Text="Please wait until your number being called from a counter !"
                           FontSize="45"
                           Foreground="White"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

            </Border>

        </Grid>

        <!--Number-->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="1"
                    Background="Brown"
                    BorderBrush="White"
                    BorderThickness="2"
                    CornerRadius="15">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="80"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="1" Grid.Row="1"
                               Text="Your Number"
                               FontSize="40"
                               Foreground="White"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                    <TextBlock Grid.Row="2"
                               Text="------------"
                               FontSize="60"
                               Foreground="White"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                    <TextBlock Grid.Row="3"
                               Text="0000"
                               FontSize="65"
                               Foreground="White"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                </Grid>

            </Border>

        </Grid>
        
        <!--Buttons-->
        <Grid Grid.Row="3">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!--Print Button-->
            <Button Grid.Column="1"
                    x:Name="PrintBttn"
                    Width="250"
                    Height="45"
                    Background="White"
                    materialDesign:ElevationAssist.Elevation="Dp8">

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="Print The Recipt  |  "
                               FontSize="18"
                               Foreground="Black"
                               VerticalAlignment="Center"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                    <materialDesign:PackIcon Kind="PrinterOutline"
                                             Width="25"
                                             Height="25"
                                             Foreground="Black"
                                             VerticalAlignment="Center"/>

                </StackPanel>

            </Button>

            <!--SMS Button-->
            <Button Grid.Column="2"
                    x:Name="SmsBttn"
                    Width="250"
                    Height="45"
                    Background="White"
                    materialDesign:ElevationAssist.Elevation="Dp8">

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="Send To Phone  |  "
                               FontSize="18"
                               Foreground="Black"
                               VerticalAlignment="Center"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                    <materialDesign:PackIcon Kind="MessageTextOutline"
                                             Width="23"
                                             Height="23"
                                             Foreground="Black"
                                             VerticalAlignment="Center"/>

                </StackPanel>

            </Button>

            <!--Cancel Button-->
            <Button Grid.Column="3"
                    x:Name="CancelBttn"
                    Width="250"
                    Height="45"
                    Background="White"
                    materialDesign:ElevationAssist.Elevation="Dp8"
                    Click="CancelBttn_Click">

                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="Cancel The Number  |  "
                               FontSize="18"
                               Foreground="Black"
                               VerticalAlignment="Center"
                               FontFamily="pack://application:,,,/assets/fonts/#Fredoka SemiBold"/>

                    <materialDesign:PackIcon Kind="DeleteOutline"
                                             Width="24"
                                             Height="24"
                                             Foreground="Black"
                                             VerticalAlignment="Center"/>

                </StackPanel>

            </Button>

        </Grid>

    </Grid>
    
</Window>
